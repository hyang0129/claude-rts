{
  "startup_script": "from-layout",
  "default_canvas": "m6-qa",
  "probe_profiles": ["hongy"],
  "probe_interval": 60,
  "sessions": {
    "orphan_timeout": 300,
    "scrollback_size": 65536,
    "tmux_persistence": true
  },
  "util_container": {
    "auto_start": true,
    "mounts": {
      "~/.claude-profiles": "/profiles"
    }
  }
}
